# Atlas WebServer backend runtime environment.
#
# Frontend Vite variables live in ../Atlas-Frontend/.env.example.

TWS_PORT=9006
TWS_DB_HOST=127.0.0.1
TWS_DB_PORT=3306
TWS_DB_USER=root
TWS_DB_PASSWORD=
TWS_DB_NAME=qgydb

TWS_UPLOAD_MAX_BYTES=104857600
TWS_USER_STORAGE_QUOTA_BYTES=1073741824
TWS_CONN_TIMEOUT=60
TWS_LOG_WRITE=1
TWS_LOG_LEVEL=1
TWS_LOG_QUEUE_SIZE=800
TWS_THREAD_NUM=8
TWS_THREADPOOL_MAX_THREADS=8
TWS_THREADPOOL_IDLE_TIMEOUT=30
TWS_THREADPOOL_QUEUE_MODE=mutex

TWS_AUTH_RATE_LIMIT_ENABLED=0
TWS_REDIS_HOST=127.0.0.1
TWS_REDIS_PORT=6379
TWS_REDIS_POOL_SIZE=4
TWS_REDIS_CONNECT_TIMEOUT_MS=80
TWS_REDIS_SOCKET_TIMEOUT_MS=80
TWS_REDIS_MAX_RETRIES=0
TWS_AUTH_LOGIN_IP_MAX_TOKENS=60
TWS_AUTH_LOGIN_IP_REFILL_RATE=1.0
TWS_AUTH_LOGIN_USER_MAX_TOKENS=10
TWS_AUTH_LOGIN_USER_REFILL_RATE=0.166667
TWS_AUTH_REGISTER_IP_MAX_TOKENS=30
TWS_AUTH_REGISTER_IP_REFILL_RATE=0.05
TWS_AUTH_RATE_LIMIT_FALLBACK_MODE=local
